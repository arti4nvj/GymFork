# Copy this file to the repo root and fill in your values:
#   cp resources_servers/cvdp/env.yaml.example env.yaml
#
# policy_base_url: OpenAI-compatible inference endpoint
#   - NVIDIA hosted API: https://inference-api.nvidia.com/v1
#   - Local vLLM:        http://localhost:8000/v1
policy_base_url: https://integrate.api.nvidia.com/v1
policy_api_key: <your-api-key>
policy_model_name: <your-model-name>  # e.g. nvidia/llama-3.1-nemotron-ultra-253b-v1